PORT=5000
MONGO_URI=mongodb://localhost:27017/idrip
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_LIFETIME=price_lifetime_id
SKIP_SEED=true

# Cloudinary (image storage)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# OpenAI (clothing analysis) — primary
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Featherless AI — fallback if OpenAI is not configured
# FEATHERLESS_API_KEY=your-featherless-api-key
# FEATHERLESS_MODEL=Qwen/Qwen3.6-27B
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# AI Service (Python, LangGraph agent)
AI_SERVICE_URL=http://localhost:8000

# Vector DB mode: "memory" (local dev) or "atlas" (production)
VECTOR_DB=memory
